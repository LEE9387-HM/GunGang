# GunGang — API 인증키 (이 파일을 .env로 복사해서 값을 채우세요. .env는 git에 올라가지 않습니다)

# 공공데이터포털(data.go.kr) 일반 인증키
# - 활용신청한 API: 건강기능식품정보(15056760), 건강기능식품 영양DB(15085712)
# - 마이페이지 > 활용신청 상세에서 "일반 인증키 (Decoding)" 값을 붙여넣으세요.
#   (Encoding 키를 넣어도 스크립트가 자동 판별합니다)
DATA_GO_KR_API_KEY=

# 식품안전나라(foodsafetykorea.go.kr) 인증키 — I2710(건강기능식품 품목분류정보)용
FOODSAFETY_API_KEY=

# Supabase (프로젝트: GunGang / pscnvtuorxjibjzkrlit / ap-northeast-2)
# 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://pscnvtuorxjibjzkrlit.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 개발자센터 — 검색(쇼핑) API. 가격 PoC용 (docs/13-pricing-strategy.md)
# developers.naver.com > 애플리케이션 등록 > 사용 API에 "검색" 추가 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
